{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@nebula/auth": ["../../packages/auth/dist/src/index.d.ts"],
      "@nebula/request": ["../../packages/request/dist/src/index.d.ts"],
      "@nebula/core": ["../../packages/core/dist/index.d.ts"]
    },
    "types": ["expo-router/types", "node"]
  },
  "include": ["app", "src", "expo-env.d.ts"]
}
