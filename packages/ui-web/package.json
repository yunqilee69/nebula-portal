{
  "name": "@nebula/ui-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json --emitDeclarationOnly false && cp src/nebula.css dist/nebula.css",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@nebula/core": "workspace:*"
  },
  "peerDependencies": {
    "antd": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
