{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@nebula/request": ["../request/dist/src/index.d.ts"],
      "@nebula/auth": ["../auth/dist/src/index.d.ts"],
      "@nebula/core": ["../core/src/index.ts"],
      "@nebula/tokens": ["../tokens/dist/src/index.d.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../request" },
    { "path": "../auth" },
    { "path": "../tokens" }
  ]
}
