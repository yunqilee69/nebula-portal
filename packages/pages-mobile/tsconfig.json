{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["react", "react-native", "node"],
    "baseUrl": ".",
    "paths": {
      "@nebula/core": ["../core/dist/index.d.ts"],
      "@nebula/tokens": ["../tokens/dist/src/index.d.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" },
    { "path": "../tokens" }
  ]
}
