{
  "name": "@nebula/pages-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nebula/core": "workspace:*",
    "@nebula/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-native": "^0.83.2",
    "@react-navigation/native": "*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
