{
  "name": "@nebula/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "import": "./src/context/index.ts"
    },
    "./event-bus": {
      "types": "./src/event-bus.ts",
      "import": "./src/event-bus.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    },
    "./menu": {
      "types": "./src/menu/index.ts",
      "import": "./src/menu/index.ts"
    },
    "./navigation": {
      "types": "./src/navigation/index.ts",
      "import": "./src/navigation/index.ts"
    },
    "./permissions": {
      "types": "./src/permissions/index.ts",
      "import": "./src/permissions/index.ts"
    },
    "./request": {
      "types": "./src/request/index.ts",
      "import": "./src/request/index.ts"
    },
    "./routing": {
      "types": "./src/routing/index.ts",
      "import": "./src/routing/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "import": "./src/storage/index.ts"
    },
    "./stores": {
      "types": "./src/stores/index.ts",
      "import": "./src/stores/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nebula/request": "workspace:*",
    "@nebula/tokens": "workspace:*",
    "axios": "^1.7.9",
    "zustand": "^5.0.0",
    "react-router-dom": "^7.6.2"
  },
  "peerDependencies": {
    "antd": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
