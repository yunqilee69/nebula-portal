    "@nebula/tokens": "workspace:*",
    "axios": "^1.7.9",
    "zustand": "^5.0.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@nebula/i18n": "workspace:*"
  },
  "peerDependencies": {
    "antd": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
